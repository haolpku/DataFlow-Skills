from dataflow import get_logger
from dataflow.core import OperatorABC
from dataflow.utils.registry import OPERATOR_REGISTRY
from dataflow.utils.storage import DataFlowStorage


@OPERATOR_REGISTRY.register()
class {{OPERATOR_CLASS_NAME}}(OperatorABC):
    """Generated DataFlow operator scaffold (filter)."""

    def __init__(self):
        super().__init__()
        self.logger = get_logger()

    @staticmethod
    def get_desc(lang: str = "zh"):
        if lang == "zh":
            return "{{OPERATOR_CLASS_NAME}}：根据规则打标并过滤数据。"
        if lang == "en":
            return "{{OPERATOR_CLASS_NAME}}: mark and filter rows by rule."
        return "Filter rows by rule."

    def run(
        self,
        storage: DataFlowStorage,
        input_key: str = "{{INPUT_KEY}}",
        output_key: str = "{{OUTPUT_KEY}}",
        min_length: int = 1,
        drop_filtered: bool = True,
    ):
        dataframe = storage.read("dataframe")
        if input_key not in dataframe.columns:
            available_columns = ", ".join(map(str, dataframe.columns.tolist())) or "<empty>"
            raise KeyError(f"Missing input column: {input_key}. Available columns: {available_columns}")

        series = dataframe[input_key].fillna("").astype(str)
        dataframe[output_key] = series.map(lambda x: len(x.strip()) >= min_length)

        if drop_filtered:
            dataframe = dataframe[dataframe[output_key]].reset_index(drop=True)

        storage.write(dataframe)
        return output_key
